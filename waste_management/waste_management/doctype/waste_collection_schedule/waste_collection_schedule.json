{
    "name": "Waste Collection Schedule",
    "module": "Waste Management",
    "doctype": "DocType",
    "is_submittable": 1,
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "schedule_name",
            "fieldtype": "Data",
            "label": "Schedule Name",
            "reqd": 1
        },
        {
            "fieldname": "zone",
            "fieldtype": "Link",
            "options": "Waste Zone",
            "label": "Zone",
            "reqd": 1
        },
        {
            "fieldname": "schedule_type",
            "fieldtype": "Select",
            "label": "Schedule Type",
            "options": "Daily\nWeekly\nCustom",
            "reqd": 1
        },
        {
            "fieldname": "start_date",
            "fieldtype": "Date",
            "label": "Start Date",
            "reqd": 1
        },
        {
            "fieldname": "end_date",
            "fieldtype": "Date",
            "label": "End Date"
        },
        {
            "fieldname": "vehicle",
            "fieldtype": "Link",
            "options": "Waste Vehicle",
            "label": "Vehicle",
            "reqd": 1
        },
        {
            "fieldname": "driver",
            "fieldtype": "Link",
            "options": "Waste Driver",
            "label": "Driver",
            "reqd": 1
        },
        {
            "fieldname": "collection_time",
            "fieldtype": "Time",
            "label": "Collection Time"
        },
        {
            "fieldname": "waste_categories",
            "fieldtype": "Table",
            "label": "Waste Categories",
            "options": "Schedule Waste Category"
        },
        {
            "fieldname": "ai_optimized",
            "fieldtype": "Check",
            "label": "AI Optimized",
            "default": "0",
            "read_only": 1
        },
        {
            "fieldname": "ai_optimization_notes",
            "fieldtype": "Text",
            "label": "AI Optimization Notes",
            "read_only": 1
        },
        {
            "fieldname": "is_active",
            "fieldtype": "Check",
            "label": "Is Active",
            "default": "1"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1
        },
        {
            "role": "Waste Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "submit": 1
        }
    ],
    "autoname": "WCS-.YYYY.-.####"
}
