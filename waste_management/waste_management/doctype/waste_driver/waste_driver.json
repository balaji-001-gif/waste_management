            "reqd": 1
        },
        {
            "fieldname": "license_type",
            "fieldtype": "Select",
            "label": "License Type",
            "options": "LMV\nHMV\nHGMV\nHPMV"
        },
        {
            "fieldname": "contact_number",
            "fieldtype": "Data",
            "label": "Contact Number"
        },
        {
            "fieldname": "emergency_contact",
