{
    "name": "Waste Disposal Site",
    "module": "Waste Management",
    "doctype": "DocType",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "site_name",
            "fieldtype": "Data",
            "label": "Site Name",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "site_code",
            "fieldtype": "Data",
            "label": "Site Code",
            "reqd": 1
        },
        {
            "fieldname": "site_type",
            "fieldtype": "Select",
            "label": "Site Type",
            "options": "Landfill\nRecycling Center\nIncineration Plant\nComposting Facility\nTransfer Station\nHazardous Waste Facility",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "address",
            "fieldtype": "Text",
            "label": "Address"
        },
        {
            "fieldname": "latitude",
            "fieldtype": "Float",
            "label": "Latitude"
        },
        {
            "fieldname": "longitude",
            "fieldtype": "Float",
            "label": "Longitude"
        },
        {
            "fieldname": "total_capacity_tons",
            "fieldtype": "Float",
            "label": "Total Capacity (tons)"
        },
        {
            "fieldname": "current_capacity_used_tons",
            "fieldtype": "Float",
            "label": "Current Capacity Used (tons)"
        },
        {
            "fieldname": "capacity_percentage",
            "fieldtype": "Percent",
            "label": "Capacity Used (%)",
            "read_only": 1
        },
        {
            "fieldname": "accepted_waste_types",
            "fieldtype": "Table MultiSelect",
            "label": "Accepted Waste Categories",
            "options": "Waste Category"
        },
        {
            "fieldname": "operating_hours",
            "fieldtype": "Data",
            "label": "Operating Hours (e.g., 08:00-18:00)"
        },
        {
            "fieldname": "operating_days",
            "fieldtype": "Data",
            "label": "Operating Days"
        },
        {
            "fieldname": "contact_person",
            "fieldtype": "Data",
            "label": "Contact Person"
        },
        {
            "fieldname": "contact_number",
            "fieldtype": "Data",
            "label": "Contact Number"
        },
        {
            "fieldname": "license_number",
            "fieldtype": "Data",
            "label": "License Number"
        },
        {
            "fieldname": "license_expiry",
            "fieldtype": "Date",
            "label": "License Expiry"
        },
        {
            "fieldname": "is_active",
            "fieldtype": "Check",
            "label": "Is Active",
            "default": "1"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "Waste Manager",
            "read": 1,
            "write": 1,
            "create": 1
        }
    ],
    "autoname": "field:site_code"
}
