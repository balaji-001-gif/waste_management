        },
        {
            "fieldname": "city",
            "fieldtype": "Data",
            "label": "City"
        },
        {
            "fieldname": "state",
            "fieldtype": "Data",
            "label": "State"
        },
        {
            "fieldname": "country",
            "fieldtype": "Link",
            "options": "Country",
            "label": "Country"
        },
        {
            "fieldname": "latitude",
            "fieldtype": "Float",
            "label": "Latitude"
        },
        {
            "fieldname": "longitude",
            "fieldtype": "Float",
            "label": "Longitude"
        },
        {
            "fieldname": "area_sq_km",
            "fieldtype": "Float",
            "label": "Area (sq km)"
        },
        {
            "fieldname": "population_estimate",
            "fieldtype": "Int",
            "label": "Population Estimate"
