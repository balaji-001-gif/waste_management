        {
            "fieldname": "zone",
            "fieldtype": "Link",
            "options": "Waste Zone",
            "label": "Zone",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "waste_category",
            "fieldtype": "Link",
            "options": "Waste Category",
            "label": "Waste Category",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "predicted_weight_kg",
