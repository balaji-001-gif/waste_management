            "label": "Predicted Weight (kg)"
        },
        {
            "fieldname": "actual_weight_kg",
            "fieldtype": "Float",
            "label": "Actual Weight (kg)"
        },
        {
            "fieldname": "variance_kg",
            "fieldtype": "Float",
            "label": "Variance (kg)",
