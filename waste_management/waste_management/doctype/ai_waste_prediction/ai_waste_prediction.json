{
    "name": "AI Waste Prediction",
    "module": "Waste Management",
    "doctype": "DocType",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "prediction_date",
            "fieldtype": "Date",
            "label": "Prediction Date",
            "reqd": 1,
            "in_list_view": 1
